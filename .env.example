OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# optional — use local inference instead (see native/)
USE_LOCAL_LLM=false
LOCAL_LLM_MODEL_PATH=./models/sambot-7b.gguf

# server
PORT=4242
HOST=localhost

# memory
MEMORY_DB_PATH=./.sambot/memory.sqlite
EMBEDDING_MODEL=text-embedding-3-small

# vision
VISION_BACKEND=openai

# sandbox
SANDBOX_TIMEOUT_MS=15000
SANDBOX_MAX_OUTPUT_BYTES=65536
